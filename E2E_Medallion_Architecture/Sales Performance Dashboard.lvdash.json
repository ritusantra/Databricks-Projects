          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "92852eb8",
      "displayName": "kpis",
      "queryLines": [
        "select count(distinct order_number) as total_orders,\r\n",
        "sum(sales_amount) as total_sales,\r\n",
        "sum(quantity) as total_qty \r\n",
        "from fact_sales; "
      ],
      "catalog": "sales_catalog",
      "schema": "gold"
    },
    {
      "name": "top_products",
      "displayName": "Top 10 Products by Sales",
      "queryLines": [
        "SELECT\n",
        "  p.product_name,\n",
        "  SUM(s.sales_amount) as total_sales\n",
        "FROM\n",
        "  sales_catalog.gold.fact_sales s\n",
        "    INNER JOIN sales_catalog.gold.dim_products p\n",
        "      ON s.product_key = p.product_key\n",
        "GROUP BY\n",
        "  p.product_name\n",
        "ORDER BY\n",
        "  total_sales DESC\n",
        "LIMIT 10"
      ],
      "catalog": "sales_catalog",
      "schema": "gold"
    },
    {
      "name": "f3d29856",
      "displayName": "sales",
      "queryLines": [
        "select \r\n",
        "  c.country,\r\n",
        "  count(distinct c.customer_id) as total_customers,\r\n",
        "  sum(fsd.quantity) as total_quantity,\r\n",
        "  sum(fsd.sales_amount) as total_sales,\r\n",
        "  count(fsd.order_number) as number_of_orders\r\n",
        "from sales_catalog.gold.dim_customers c\r\n",
        "join sales_catalog.gold.fact_sales fsd\r\n",
        "  on c.customer_key = fsd.customer_key\r\n",
        "group by c.country"
      ],
      "catalog": "sales_catalog",
      "schema": "gold"
    },
    {
      "name": "73b751d2",
      "displayName": "cust_seg",
      "queryLines": [
        "with v as (\r\n",
        "  SELECT \r\n",
        "    c.custmer_number, \r\n",
        "    sum(f.quantity) as total_qty\r\n",
        "  FROM sales_catalog.gold.fact_sales f\r\n",
        "  INNER JOIN sales_catalog.gold.dim_customers c\r\n",
        "    ON f.customer_key = c.customer_key\r\n",
        "  GROUP BY c.custmer_number\r\n",
        ")\r\n",
        "select \r\n",
        "  custmer_number, total_qty,\r\n",
        "  case \r\n",
        "    when total_qty > 40 then 'Tier-1'\r\n",
        "    when total_qty >= 20 and total_qty <= 40 then 'Tier-2'\r\n",
        "    when total_qty < 20 then 'Tier-3'\r\n",
        "  end as cust_tier\r\n",
        "from v "
      ],
      "catalog": "sales_catalog",
      "schema": "gold"
    },
    {
      "name": "2bd5a1cf",
      "displayName": "qty_trends",
      "queryLines": [
        "select \r\n",
        "  year(order_date) as order_year, \r\n",
        "  sum(quantity) as total_quantity\r\n",
        "from sales_catalog.gold.fact_sales\r\n",
        "where order_date is not null\r\n",
        "group by year(order_date);"
      ]
    }
  ],
