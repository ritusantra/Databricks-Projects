{
  "datasets": [
    {
      "name": "2ede12e8",
      "displayName": "Location Data",
      "queryLines": [
        "select latitude, longitude, \r\n",
        "`GHG emissions mtons CO2e` as emissions\r\n",
        "from emissions_data"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "189120e8",
      "displayName": "Emissions Per Person",
      "queryLines": [
        "select county_state_name, population,\r\n",
        "  cast(\r\n",
        "    replace(\r\n",
        "      `GHG emissions mtons CO2e`, \r\n",
        "      ',', \r\n",
        "      ''\r\n",
        "    ) as double\r\n",
        "  ) / cast(\r\n",
        "    replace(\r\n",
        "      population, \r\n",
        "      ',', \r\n",
        "      ''\r\n",
        "    ) as double\r\n",
        "  ) as emissions_per_person\r\n",
        "from emissions_data\r\n",
        "order by emissions_per_person desc"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "c1566be5",
      "displayName": "Total Emissions Per State",
      "queryLines": [
        "select state_abbr, \r\n",
        "  sum(cast(\r\n",
        "    replace(\r\n",
        "      `GHG emissions mtons CO2e`, \r\n",
        "      ',', \r\n",
        "      ''\r\n",
        "    ) as double\r\n",
        "  )) as total_emissions\r\n",
        "from emissions_data\r\n",
        "group by state_abbr\r\n",
        "order by total_emissions desc\r\n",
        "limit 10;"
      ],
      "catalog": "emissions",
      "schema": "default"
    },
    {
      "name": "3690ddbd",
      "displayName": "Emissions Per County",
      "queryLines": [
        "select county_state_name, population,\r\n",
        "  cast(\r\n",
        "    replace(\r\n",
        "      `GHG emissions mtons CO2e`, \r\n",
        "      ',', \r\n",
        "      ''\r\n",
        "    ) as double\r\n",
        "  ) as total_emissions\r\n",
        "from emissions_data\r\n",
        "order by total_emissions desc\r\n",
        "limit 10;"
      ],
      "catalog": "emissions",
      "schema": "default"
    }
  ],
