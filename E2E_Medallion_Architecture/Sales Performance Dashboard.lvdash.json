{
  "datasets": [
    {
      "name": "3bfbd819",
      "displayName": "Quantity by Country",
      "queryLines": [
        "select c.country, sum(s.quantity) as total_quantity\r\n",
        "from fact_sales s\r\n",
        "inner join dim_customers c \r\n",
        "on s.customer_key = c.customer_id\r\n",
        "group by c.country\r\n",
        "order by sum(s.quantity) desc;"
      ],
      "catalog": "sales_catalog",
      "schema": "gold"
    },
    {
      "name": "d677ba98",
      "displayName": "fact_sales",
      "config": {
        "version": "1.1",
        "source": "sales_catalog.gold.fact_sales",
        "dimensions": [
